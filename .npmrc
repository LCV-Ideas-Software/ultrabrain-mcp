# StepSecurity Secure Registry — install via proxy with security gating.
# Local dev: token in ~/.npmrc; CI: STEPSECURITY_NPM_TOKEN env var via org secret.
registry=https://registry.stepsecurity.io/javascript
//registry.stepsecurity.io/javascript/:_authToken=${STEPSECURITY_NPM_TOKEN}

# Scope override: @lcv-ideas-software/* publishes go to npmjs.org direct (proxy is read-only).
# Auth for publish comes from setup-node-injected $HOME/.npmrc (NODE_AUTH_TOKEN via OIDC trusted publisher).
@lcv-ideas-software:registry=https://registry.npmjs.org/
